-- ============================================================================
-- CONDITIONAL FAST PUNCH MANAGER
-- ============================================================================
local function ManagePunchConnection()
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LocalPlayer = Players.LocalPlayer
    
    -- Check if any rock switch is currently active
    local anyFarmActive = false
    for _, isActive in pairs(_G.ActiveRockFarms) do
        if isActive then
            anyFarmActive = true
            break
        end
    end

    -- If a farm is active and no loop exists, start it
    if anyFarmActive then
        if not _G.PunchConnection then
            local muscleEvent = LocalPlayer:WaitForChild("muscleEvent", 5)
            if muscleEvent then
                local args = {
                    [1] = "punch",
                    [2] = "rightHand"
                }

                _G.PunchConnection = RunService.Heartbeat:Connect(function()
                    local Character = LocalPlayer.Character
                    if not Character then return end
                    
                    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                    if not Humanoid or Humanoid.Health <= 0 then return end

                    -- AUTO EQUIP: Checks backpack and forces character to hold it
                    local PunchTool = LocalPlayer.Backpack:FindFirstChild("Punch")
                    if PunchTool then
                        Humanoid:EquipTool(PunchTool)
                    end

                    -- Fires the remote damage event instantly
                    muscleEvent:FireServer(unpack(args))
                end)
            else
                warn("muscleEvent not found! Make sure you are fully loaded into the game.")
            end
        end
    else
        -- If no farms are active, completely shut down the punch loop
        if _G.PunchConnection then
            _G.PunchConnection:Disconnect()
            _G.PunchConnection = nil
        end
    end
end

-- Clean up any rogue connections from previous script runs
if _G.PunchConnection then
    _G.PunchConnection:Disconnect()
    _G.PunchConnection = nil
end

