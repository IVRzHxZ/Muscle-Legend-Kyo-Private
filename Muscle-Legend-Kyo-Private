-- Centralized Function to Handle All Rock Farms Safely
local function ToggleRock(keywordName, configName, enabled, originalSize, staticSpawnCFrame, isExactName)
    _G[configName .. "autorock"] = enabled
    
    if enabled then
        task.spawn(function()
            local _LocalPlayer = game.Players.LocalPlayer
            
            while _G[configName .. "autorock"] do
                local char = _LocalPlayer.Character
                local _LeftHand = char and char:FindFirstChild('LeftHand')
                
                -- Dynamic search system with strict matching validation
                local targetFolder = nil
                local machines = game.Workspace:FindFirstChild("machinesFolder")
                if machines then
                    for _, child in ipairs(machines:GetChildren()) do
                        if isExactName then
                            -- FIXED: Gagamit ng exact match para hindi magkapalit ang Golden at Punching
                            if child.Name == keywordName then
                                targetFolder = child
                                break
                            end
                        else
                            if string.find(string.lower(child.Name), string.lower(keywordName)) then
                                targetFolder = child
                                break
                            end
                        end
                    end
                end
                
                local _Rock = targetFolder and targetFolder:FindFirstChild('Rock')
                
                if _Rock and _LeftHand then
                    _Rock.Size = Vector3.new(12, 12, 12)
                    _Rock.Transparency = 1
                    _Rock.CanCollide = false
                    
                    if _Rock:FindFirstChild('rockGui') then
                        for _, guiItem in ipairs(_Rock.rockGui:GetChildren()) do
                            pcall(function() guiItem.Visible = false end)
                        end
                    end
                    
                    -- Clean up particle and effect clutter
                    local particleNames = {'rockEmitter', 'hoopParticle', 'lavaParticle'}
                    for _, particleName in ipairs(particleNames) do
                        local effect = _Rock:FindFirstChild(particleName)
                        if effect then effect:Destroy() end
                    end
                    
                    -- Loops and brings the rock directly to your left hand wherever you stand
                    _Rock.CFrame = _LeftHand.CFrame
                else
                    warn("Machine folder containing keyword '" .. keywordName .. "' or LeftHand missing.")
                end
                task.wait(0.01) -- Quick loop interval for clean loop-bring snapping
            end
        end)
    else
        -- Clean reset state logic using the same strict scanning method
        pcall(function()
            local targetFolder = nil
            local machines = game.Workspace:FindFirstChild("machinesFolder")
            if machines then
                for _, child in ipairs(machines:GetChildren()) do
                    if isExactName then
                        if child.Name == keywordName then
                            targetFolder = child
                            break
                        end
                    else
                        if string.find(string.lower(child.Name), string.lower(keywordName)) then
                            targetFolder = child
                            break
                        end
                    end
                end
            end
            
            local _Rock = targetFolder and targetFolder:FindFirstChild('Rock')
            if _Rock then
                if _Rock:FindFirstChild('rockGui') then
                    for _, guiItem in ipairs(_Rock.rockGui:GetChildren()) do
                        pcall(function() guiItem.Visible = true end)
                    end
                end
                _Rock.CanCollide = false
                _Rock.Transparency = 1
                _Rock.Size = originalSize
                if _Rock:FindFirstChild('originalPosition') then 
                    _Rock.CFrame = CFrame.new(_Rock.originalPosition.Value) 
                elseif staticSpawnCFrame then
                    _Rock.CFrame = staticSpawnCFrame
                end
            end
        end)
    end
end

