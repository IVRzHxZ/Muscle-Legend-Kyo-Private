-- Number Abbreviation Engine (1000 -> 1K)
local suffixes = {"K", "M", "B", "T", "QA", "QI"}
local function formatNumber(value)
    if not value or typeof(value) ~= "number" then return "0" end
    if value < 1000 then return tostring(value) end
    
    local index = math.floor(math.log10(value) / 3)
    local suffix = suffixes[index] or ""
    local abbreviated = value / (10 ^ (index * 3))
    
    return string.format("%.1f", abbreviated):gsub("%.0$", "") .. suffix
end

-- Advanced Case-Insensitive Deep Search Logic to fix Good/Evil Karma issues
local function locatePlayerStatObject(targetPlayer, statName)
    if not targetPlayer then return nil end
    local cleanTarget = string.lower(string.gsub(statName, "%s+", ""))
    local possibleFolders = {"leaderstats", "Stats", "Data", "leaderstats2", "Karma", "Currency"}
    
    for _, folderName in ipairs(possibleFolders) do
        local folder = targetPlayer:FindFirstChild(folderName)
        if folder then
            for _, child in ipairs(folder:GetChildren()) do
                local cleanChildName = string.lower(string.gsub(child.Name, "%s+", ""))
                if cleanChildName == cleanTarget then return child end
            end
        end
    end
    
    for _, child in ipairs(targetPlayer:GetChildren()) do
        local cleanChildName = string.lower(string.gsub(child.Name, "%s+", ""))
        if cleanChildName == cleanTarget then return child end
    end
    return nil
end

